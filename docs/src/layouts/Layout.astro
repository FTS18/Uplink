---
interface Props {
  title: string;
  description?: string;
  showSidebar?: boolean;
  activeSlug?: string;
}

const {
  title,
  description = "A minimal, native network speed monitor that lives in your Windows 11 taskbar. No bloat, no electron, no background services.",
  showSidebar = false,
  activeSlug = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://github.com/FTS18/BitBar");
const ogImageURL = "https://raw.githubusercontent.com/FTS18/BitBar/main/assets/logo.png";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | BitBar</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | BitBar`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | BitBar`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href="/" class="brand">
          <span class="brand-icon">◈</span>
          <span class="brand-name">BitBar</span>
        </a>
        <nav class="nav">
          <a href="/docs/install" class={activeSlug.startsWith("docs") ? "nav-link nav-active" : "nav-link"}>Docs</a>
          <a href="https://github.com/FTS18/BitBar" target="_blank" rel="noopener noreferrer" class="nav-link nav-github">
            GitHub
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="page-body">
      {showSidebar && (
        <aside class="sidebar">
          <div class="sidebar-group">
            <p class="sidebar-label">Getting Started</p>
            <ul class="sidebar-list">
              <li><a href="/docs/install" class={activeSlug === "install" ? "sidebar-link sidebar-active" : "sidebar-link"}>Installation</a></li>
            </ul>
          </div>
          <div class="sidebar-group">
            <p class="sidebar-label">Configuration</p>
            <ul class="sidebar-list">
              <li><a href="/docs/settings" class={activeSlug === "settings" ? "sidebar-link sidebar-active" : "sidebar-link"}>Settings</a></li>
              <li><a href="/docs/troubleshooting" class={activeSlug === "troubleshooting" ? "sidebar-link sidebar-active" : "sidebar-link"}>Troubleshooting</a></li>
            </ul>
          </div>
        </aside>
      )}
      <main class={showSidebar ? "main with-sidebar" : "main"}>
        <slot />
      </main>
    </div>

    <footer class="footer">
      <div class="footer-inner">
        <span class="brand-icon" style="opacity:0.3">◈</span>
        <p>BitBar — MIT License · <a href="https://github.com/FTS18/BitBar" target="_blank">GitHub</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Cream palette */
    --cream-50:  #FEFDF8;
    --cream-100: #FAF8EF;
    --cream-200: #F2EFE3;
    --cream-300: #E6E1D0;
    --cream-400: #D0C9B2;

    /* Black palette */
    --ink-900: #0D0C09;
    --ink-700: #2A2820;
    --ink-500: #57544A;
    --ink-300: #9B9789;

    --accent: var(--ink-900);
    --bg: var(--cream-50);
    --surface: var(--cream-100);
    --border: var(--cream-300);

    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'Plus Jakarta Sans', system-ui, sans-serif;
    --mono: 'IBM Plex Mono', 'Courier New', monospace;

    --r: 6px;
    --max-w: 1040px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink-700);
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; }

  /* ── Header ─────────────────────────── */
  .header {
    position: sticky; top: 0; z-index: 50;
    background: var(--bg);
    border-bottom: 1.5px solid var(--border);
  }

  .header-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--serif);
    font-size: 1.25rem;
    color: var(--ink-900);
    letter-spacing: -0.01em;
  }

  .brand-icon { font-size: 1.1rem; opacity: 0.7; }

  .nav { display: flex; align-items: center; gap: 0.25rem; }

  .nav-link {
    padding: 0.4rem 0.85rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink-500);
    border-radius: var(--r);
    transition: background 0.15s, color 0.15s;
    display: flex; align-items: center; gap: 0.3rem;
  }

  .nav-link:hover { background: var(--cream-200); color: var(--ink-900); }
  .nav-active { color: var(--ink-900); background: var(--cream-200); }

  .nav-github {
    background: var(--ink-900);
    color: var(--cream-50) !important;
    margin-left: 0.5rem;
  }
  .nav-github:hover { background: var(--ink-700); }

  /* ── Page Body ───────────────────────── */
  .page-body {
    flex: 1;
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
    display: flex;
    padding: 2.5rem 2rem;
    gap: 3rem;
  }

  /* ── Sidebar ─────────────────────────── */
  .sidebar {
    width: 200px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.25rem;
  }

  .sidebar-group { display: flex; flex-direction: column; gap: 0.4rem; }

  .sidebar-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-300);
    padding: 0 0.5rem;
    margin-bottom: 0.2rem;
  }

  .sidebar-list { list-style: none; }

  .sidebar-link {
    display: block;
    padding: 0.35rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-500);
    transition: all 0.12s;
  }
  .sidebar-link:hover { background: var(--cream-200); color: var(--ink-900); }
  .sidebar-active {
    background: var(--ink-900);
    color: var(--cream-50);
    font-weight: 600;
  }
  .sidebar-active:hover { background: var(--ink-700); color: var(--cream-50); }

  /* ── Main Content ────────────────────── */
  .main { flex: 1; min-width: 0; }
  .with-sidebar { /* no change needed */ }

  /* ── Typography (for doc pages) ──────── */
  .prose h1 {
    font-family: var(--serif);
    font-size: 2.25rem;
    font-weight: 400;
    line-height: 1.2;
    color: var(--ink-900);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .prose .lead {
    font-size: 1.05rem;
    color: var(--ink-500);
    margin-bottom: 2.5rem;
    border-bottom: 1.5px solid var(--border);
    padding-bottom: 1.5rem;
  }

  .prose h2 {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--ink-900);
    margin: 2.5rem 0 0.75rem;
  }

  .prose h3 {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-500);
    margin: 1.75rem 0 0.5rem;
  }

  .prose p { margin-bottom: 1rem; color: var(--ink-700); line-height: 1.7; }

  .prose ul, .prose ol {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .prose li { margin-bottom: 0.4rem; color: var(--ink-700); }

  .prose code {
    font-family: var(--mono);
    font-size: 0.82em;
    background: var(--cream-200);
    color: var(--ink-900);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid var(--border);
  }

  .prose pre {
    background: var(--ink-900);
    color: var(--cream-200);
    border-radius: var(--r);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.25rem 0;
    font-family: var(--mono);
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .prose a { color: var(--ink-900); text-decoration: underline; text-underline-offset: 3px; }

  /* Alert box */
  .alert {
    background: var(--cream-100);
    border: 1.5px solid var(--border);
    border-left: 4px solid var(--ink-900);
    border-radius: 0 var(--r) var(--r) 0;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .alert-title {
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    color: var(--ink-900);
  }
  .alert p { margin-bottom: 0; font-size: 0.9rem; }

  /* Table */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose th {
    background: var(--cream-200);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-500);
    padding: 0.65rem 1rem;
    text-align: left;
    border-bottom: 2px solid var(--border);
  }
  .prose td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--ink-700);
  }
  .prose tr:last-child td { border-bottom: none; }
  .prose tr:hover td { background: var(--cream-100); }

  /* ── Footer ──────────────────────────── */
  .footer {
    border-top: 1.5px solid var(--border);
    background: var(--cream-100);
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--ink-300);
  }
  .footer-inner a { color: var(--ink-500); text-decoration: underline; text-underline-offset: 3px; }

  /* ── Utility ─────────────────────────── */
  .btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.65rem 1.3rem;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: var(--r);
    transition: all 0.15s;
    cursor: pointer;
    border: none;
  }
  .btn-dark { background: var(--ink-900); color: var(--cream-50); }
  .btn-dark:hover { background: var(--ink-700); }
  .btn-outline { background: transparent; color: var(--ink-900); border: 1.5px solid var(--ink-900); }
  .btn-outline:hover { background: var(--cream-200); }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 768px) {
    .page-body { flex-direction: column; padding: 1.5rem 1.25rem; }
    .sidebar { width: 100%; border-bottom: 1.5px solid var(--border); padding-bottom: 1.5rem; }
    .header-inner { padding: 0 1.25rem; }
  }
</style>
