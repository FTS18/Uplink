---
import Layout from '../layouts/Layout.astro';

// ── Fetch latest release from GitHub at build time ──────────────────────────
const REPO = 'FTS18/BitBar';
const FALLBACK_URL = `https://github.com/${REPO}/releases/latest`;

interface GhAsset {
  name: string;
  size: number;
  browser_download_url: string;
}
interface GhRelease {
  tag_name: string;
  name: string;
  assets: GhAsset[];
}

let downloadUrl  = FALLBACK_URL;
let version      = '';
let assetName    = 'BitBar.exe';
let fileSizeMB   = '';
let stars        = 0;

try {
  const res  = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const rel: GhRelease = await res.json();
    version = rel.tag_name;                                          // e.g. "v1.0.0"
    const exe = rel.assets.find((a) => a.name.endsWith('.exe'));
    if (exe) {
      downloadUrl = exe.browser_download_url;
      assetName   = exe.name;
      fileSizeMB  = (exe.size / 1_048_576).toFixed(1);              // bytes → MB
    }
  }
} catch (_) {
  // Silent fallback — link goes to releases page
}

// Fetch repo stats
try {
  const repoRes = await fetch(`https://api.github.com/repos/${REPO}`, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (repoRes.ok) {
    const data = await repoRes.json();
    stars = data.stargazers_count || 0;
  }
} catch (_) {}

const btnLabel = version
  ? `Download ${assetName} (${version})`
  : `Download BitBar.exe`;
---

<Layout title="Home" stars={stars}>

  <!-- HERO -->
  <section class="hero">

    <!-- Left: Text + CTA -->
    <div class="hero-left">
      <p class="eyebrow">Open-source &middot; Windows native &middot; MIT License</p>

      <h1>Your network speed.<br /><em>Always visible.</em></h1>

      <p class="hero-desc">
        BitBar sits in your Windows 11 taskbar showing live upload and
        download speeds — no Electron, no background service, no bloat.
      </p>

      <div class="hero-actions">
        <a
          href={downloadUrl}
          download
          class="btn btn-dark"
        >
          {btnLabel}
        </a>
        <a href="/docs/install" class="btn btn-outline">Read the docs</a>
      </div>

      <div class="hero-badges-ticker">
        <div class="ticker-track">
          <div class="ticker-content">
            {version && <span class="badge badge-version">{version}</span>}
            <span class="badge">Windows 11</span>
            <span class="badge">No background service</span>
            <span class="badge">.NET 10{fileSizeMB ? ` · ${fileSizeMB} MB` : ' · ~5 MB'}</span>
          </div>
          <div class="ticker-content" aria-hidden="true">
            {version && <span class="badge badge-version">{version}</span>}
            <span class="badge">Windows 11</span>
            <span class="badge">No background service</span>
            <span class="badge">.NET 10{fileSizeMB ? ` · ${fileSizeMB} MB` : ' · ~5 MB'}</span>
          </div>
        </div>
      </div>

      <!-- Inline stats row -->
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">0 MB</span>
          <span class="stat-label">idle memory</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">&lt;0.1%</span>
          <span class="stat-label">CPU overhead</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">~5 MB</span>
          <span class="stat-label">binary size</span>
        </div>
      </div>
    </div>

    <!-- Right: Logo -->
    <div class="hero-right">
      <img
        src="/logo.png"
        alt="BitBar logo"
        class="hero-logo"
        draggable="false"
      />
    </div>

  </section>

  <div class="rule reveal-on-scroll"></div>

  <!-- DEMO PLACEHOLDER -->
  <section class="section reveal-on-scroll">
    <div class="demo-placeholder">
      <div class="demo-content">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>
        <p>Drop your Demo GIF/Video here</p>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <h2 class="section-heading reveal-on-scroll">Why BitBar?</h2>
    <div class="features reveal-on-scroll">
      <div class="feature">
        <p class="feature-title">Taskbar-native</p>
        <p class="feature-desc">Renders directly inside the Windows 11 taskbar. No floating windows, no system tray clutter.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Process tracking</p>
        <p class="feature-desc">Hover to instantly see which application is consuming the most bandwidth at any given moment.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Theme-aware</p>
        <p class="feature-desc">Detects light and dark system themes automatically, rendering natively in both modes.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Auto-fade on idle</p>
        <p class="feature-desc">Fades gracefully when the network is quiet. Zero visual noise when nothing is happening.</p>
      </div>
    </div>
  </section>

  <div class="rule reveal-on-scroll"></div>

  <!-- INSTALL -->
  <section class="section reveal-on-scroll">
    <h2 class="section-heading">Install in seconds</h2>
    <div class="install-box">
      <code id="install-code">winget install FTS18.BitBar</code>
      <button class="btn btn-outline copy-btn" onclick="navigator.clipboard.writeText(document.getElementById('install-code').innerText); this.innerText='Copied!'; setTimeout(()=>this.innerText='Copy',2000)">Copy</button>
    </div>
  </section>

  <div class="rule reveal-on-scroll"></div>

  <!-- SPECS -->
  <section class="section">
    <h2 class="section-heading reveal-on-scroll">System Requirements</h2>
    <div class="prose reveal-on-scroll">
      <table>
        <thead>
          <tr><th>Requirement</th><th>Detail</th></tr>
        </thead>
        <tbody>
          <tr><td>Operating System</td><td>Windows 10 22H2 or later (Windows 11 recommended)</td></tr>
          <tr><td>Runtime</td><td>.NET 10.0 Desktop Runtime (x64)</td></tr>
          <tr><td>Disk space</td><td>Under 5 MB (single-file executable)</td></tr>
          <tr><td>Memory</td><td>~20 MB RAM during active monitoring</td></tr>
          <tr><td>CPU overhead</td><td>Less than 0.1% on typical modern hardware</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <div class="rule reveal-on-scroll"></div>

  <!-- FAQ -->
  <section class="section reveal-on-scroll">
    <h2 class="section-heading">Frequently Asked Questions</h2>
    <div class="faq">
      <details class="faq-item">
        <summary>Does this work on Windows 10?</summary>
        <p>Yes, BitBar works on Windows 10 (22H2 or later), but it is heavily optimized for the Windows 11 taskbar experience.</p>
      </details>
      <details class="faq-item">
        <summary>Does it consume a lot of battery?</summary>
        <p>Not at all. BitBar has a CPU overhead of less than 0.1% and auto-fades when the network is idle.</p>
      </details>
      <details class="faq-item">
        <summary>How do I uninstall it?</summary>
        <p>Simply delete the single `.exe` file. BitBar leaves no registry keys or background services behind.</p>
      </details>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero layout ──────────────────── */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 2rem;
    align-items: center;
    padding: 2.5rem 0 2rem;
  }

  /* ── Left column ──────────────────── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  /* Staggered entrance animations (delayed to account for 2s splash screen) */
  .hero-left > * {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(15px);
  }
  .hero-left .eyebrow { animation-delay: 2.1s; }
  .hero-left h1 { animation-delay: 2.15s; }
  .hero-left .hero-desc { animation-delay: 2.2s; }
  .hero-left .hero-actions { animation-delay: 2.25s; }
  .hero-left .hero-badges-ticker { animation-delay: 2.3s; }
  .hero-left .hero-stats { animation-delay: 2.35s; }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-300);
    margin: 0;
  }

  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.75rem;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink-900);
    margin: 0;
  }

  h1 em {
    font-style: italic;
    color: var(--ink-400, #7a7567);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--ink-500);
    line-height: 1.7;
    margin: 0;
    max-width: 42ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .hero-badges-ticker {
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    align-self: stretch;
    position: relative;
    padding: 0.2rem 0;
    mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 3%, black 97%, transparent);
    display: flex;
  }

  .ticker-track {
    display: flex;
    width: max-content;
    animation: tickerScroll 18s linear infinite;
  }

  .ticker-content {
    display: flex;
    gap: 0.75rem;
    padding-right: 0.75rem;
    align-items: center;
  }

  @keyframes tickerScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--ink-700);
    background: var(--cream-200);
    border: 1.5px solid var(--cream-400);
    padding: 0.22rem 0.75rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .badge-version {
    background: var(--ink-900);
    color: var(--cream-50);
    border-color: var(--ink-900);
  }

  /* ── Stats row ────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-top: 0.25rem;
    border-top: 1.5px solid var(--cream-200);
    margin-top: 0.25rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink-900);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-300);
  }

  .stat-div {
    width: 1px;
    height: 28px;
    background: var(--cream-300);
  }

  /* ── Right column: Logo ───────────── */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    animation: fadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) 2.3s forwards;
    opacity: 0;
    transform: translateY(15px);
  }

  /* Subtle soft glow behind the logo */
  .hero-right::before {
    content: '';
    position: absolute;
    width: 250px;
    height: 250px;
    background: rgba(0, 0, 0, 0.05);
    filter: blur(60px);
    border-radius: 50%;
    z-index: -1;
  }

  .hero-logo {
    width: 100%;
    max-width: 360px;
    height: auto;
    aspect-ratio: 1;
    object-fit: contain;
    filter: invert(1) drop-shadow(0 8px 32px rgba(0,0,0,0.15));
    user-select: none;
    -webkit-user-drag: none;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* ── Shared ───────────────────────── */
  .rule {
    height: 1.5px;
    background: var(--cream-200);
    margin: 0.5rem 0;
  }

  .section { padding: 2.5rem 0; }

  .section-heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: var(--ink-900);
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
  }

  /* ── Features bento ───────────────── */
  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--cream-300);
    border: 1.5px solid var(--cream-300);
    border-radius: 8px;
    overflow: hidden;
  }

  .feature {
    background: var(--bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.12s;
  }

  .feature:hover { background: var(--cream-100); }

  .feature-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ink-900);
    margin: 0;
  }

  .feature-desc {
    font-size: 0.85rem;
    color: var(--ink-500);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Demo Placeholder ─────────────── */
  .demo-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    max-height: 480px;
    background: var(--cream-100);
    border: 2px dashed var(--cream-400);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-300);
    margin: 1rem 0;
  }
  .demo-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* ── Install Box ──────────────────── */
  .install-box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--cream-100);
    border: 1.5px solid var(--cream-300);
    border-radius: 12px;
    padding: 0.5rem 0.5rem 0.5rem 1.25rem;
  }
  .install-box code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink-900);
  }
  .install-box .copy-btn { padding: 0.5rem 1.25rem; font-size: 0.85rem; border-radius: 8px; }

  /* ── FAQ ──────────────────────────── */
  .faq { display: flex; flex-direction: column; gap: 1rem; }
  .faq-item {
    background: var(--cream-100);
    border: 1.5px solid var(--cream-300);
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }
  .faq-item summary {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--ink-900);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--ink-500); }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p {
    margin: 1rem 0 0;
    font-size: 0.9rem;
    color: var(--ink-700);
    line-height: 1.6;
  }

  /* ── Mobile ────────────────────────── */
  @media (max-width: 800px) {

    /* Stack hero vertically, centered */
    .hero {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 1.75rem 0 1.5rem;
      text-align: center;
    }

    /* Hide logo in hero on mobile */
    .hero-right {
      display: none;
    }

    /* Left content centered */
    .hero-left {
      align-items: center;
      gap: 0.9rem;
    }

    .eyebrow { font-size: 0.68rem; }

    h1 {
      font-size: 2.4rem;
      letter-spacing: -0.025em;
    }

    .hero-desc {
      font-size: 0.925rem;
      max-width: 36ch;
      text-align: center;
    }

    /* Single full-width CTA, text link below */
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
      width: 100%;
    }

    .hero-actions .btn-dark {
      width: 100%;
      justify-content: center;
      padding: 0.85rem 1rem;
      font-size: 0.95rem;
    }

    .hero-actions .btn-outline {
      border: none;
      background: none;
      color: var(--ink-400, var(--ink-500));
      font-size: 0.85rem;
      font-weight: 600;
      padding: 0.25rem;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-align: center;
      justify-content: center;
    }



    .hero-badges-ticker {
      display: none; /* Hide ticker on mobile to prevent clutter & overflow */
    }

    /* Hide stats row on mobile — too cluttered */
    .hero-stats { display: none; }

    /* Single-col features */
    .features {
      grid-template-columns: 1fr;
      border-radius: 8px;
    }

    /* Tighter feature cells */
    .feature { padding: 1.1rem 1.25rem; }

    .section { padding: 1.75rem 0; }

    .section-heading {
      font-size: 1.6rem;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .rule { margin: 0.25rem 0; }
  }
</style>
