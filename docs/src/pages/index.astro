---
import Layout from '../layouts/Layout.astro';

// ── Fetch latest release from GitHub at build time ──────────────────────────
const REPO = 'FTS18/BitBar';
const FALLBACK_URL = `https://github.com/${REPO}/releases/latest`;

interface GhAsset {
  name: string;
  size: number;
  browser_download_url: string;
}
interface GhRelease {
  tag_name: string;
  name: string;
  assets: GhAsset[];
}

let downloadUrl  = FALLBACK_URL;
let version      = '';
let assetName    = 'BitBar.exe';
let fileSizeMB   = '';

try {
  const res  = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const rel: GhRelease = await res.json();
    version = rel.tag_name;                                          // e.g. "v1.0.0"
    const exe = rel.assets.find((a) => a.name.endsWith('.exe'));
    if (exe) {
      downloadUrl = exe.browser_download_url;
      assetName   = exe.name;
      fileSizeMB  = (exe.size / 1_048_576).toFixed(1);              // bytes → MB
    }
  }
} catch (_) {
  // Silent fallback — link goes to releases page
}

const btnLabel = version
  ? `Download ${assetName} (${version})`
  : `Download BitBar.exe`;
---

<Layout title="Home">

  <!-- HERO -->
  <section class="hero">

    <!-- Left: Text + CTA -->
    <div class="hero-left">
      <p class="eyebrow">Open-source &middot; Windows native &middot; MIT License</p>

      <h1>Your network speed.<br /><em>Always visible.</em></h1>

      <p class="hero-desc">
        BitBar sits in your Windows 11 taskbar showing live upload and
        download speeds — no Electron, no background service, no bloat.
      </p>

      <div class="hero-actions">
        <a
          href={downloadUrl}
          download
          class="btn btn-dark"
        >
          {btnLabel}
        </a>
        <a href="/docs/install" class="btn btn-outline">Read the docs</a>
      </div>

      <div class="hero-badges">
        {version && <span class="badge badge-version">{version}</span>}
        <span class="badge">Windows 11</span>
        <span class="badge">No background service</span>
        <span class="badge">.NET 10{fileSizeMB ? ` · ${fileSizeMB} MB` : ' · ~5 MB'}</span>
      </div>

      <!-- Inline stats row -->
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">0 MB</span>
          <span class="stat-label">idle memory</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">&lt;0.1%</span>
          <span class="stat-label">CPU overhead</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num">~5 MB</span>
          <span class="stat-label">binary size</span>
        </div>
      </div>
    </div>

    <!-- Right: Logo -->
    <div class="hero-right">
      <img
        src="/logo.png"
        alt="BitBar logo"
        class="hero-logo"
        draggable="false"
      />
    </div>

  </section>

  <div class="rule"></div>

  <!-- FEATURES -->
  <section class="section">
    <h2 class="section-heading">Why BitBar?</h2>
    <div class="features">
      <div class="feature">
        <p class="feature-title">Taskbar-native</p>
        <p class="feature-desc">Renders directly inside the Windows 11 taskbar. No floating windows, no system tray clutter.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Process tracking</p>
        <p class="feature-desc">Hover to instantly see which application is consuming the most bandwidth at any given moment.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Theme-aware</p>
        <p class="feature-desc">Detects light and dark system themes automatically, rendering natively in both modes.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Auto-fade on idle</p>
        <p class="feature-desc">Fades gracefully when the network is quiet. Zero visual noise when nothing is happening.</p>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  <!-- SPECS -->
  <section class="section">
    <h2 class="section-heading">System Requirements</h2>
    <div class="prose">
      <table>
        <thead>
          <tr><th>Requirement</th><th>Detail</th></tr>
        </thead>
        <tbody>
          <tr><td>Operating System</td><td>Windows 10 22H2 or later (Windows 11 recommended)</td></tr>
          <tr><td>Runtime</td><td>.NET 10.0 Desktop Runtime (x64)</td></tr>
          <tr><td>Disk space</td><td>Under 5 MB (single-file executable)</td></tr>
          <tr><td>Memory</td><td>~20 MB RAM during active monitoring</td></tr>
          <tr><td>CPU overhead</td><td>Less than 0.1% on typical modern hardware</td></tr>
        </tbody>
      </table>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero layout ──────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2rem;
    align-items: center;
    padding: 2.5rem 0 2rem;
  }

  /* ── Left column ──────────────────── */
  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-300);
    margin: 0;
  }

  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.75rem;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink-900);
    margin: 0;
  }

  h1 em {
    font-style: italic;
    color: var(--ink-400, #7a7567);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--ink-500);
    line-height: 1.7;
    margin: 0;
    max-width: 42ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .hero-badges {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--ink-500);
    background: var(--cream-200);
    border: 1px solid var(--cream-300);
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
  }

  .badge-version {
    background: var(--ink-900);
    color: var(--cream-50);
    border-color: var(--ink-900);
  }

  /* ── Stats row ────────────────────── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-top: 0.25rem;
    border-top: 1.5px solid var(--cream-200);
    margin-top: 0.25rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink-900);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-300);
  }

  .stat-div {
    width: 1px;
    height: 28px;
    background: var(--cream-300);
  }

  /* ── Right column: Logo ───────────── */
  .hero-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 100%;
    max-width: 360px;
    height: auto;
    aspect-ratio: 1;
    object-fit: contain;
    filter: invert(1) drop-shadow(0 4px 24px rgba(0,0,0,0.12));
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ── Shared ───────────────────────── */
  .rule {
    height: 1.5px;
    background: var(--cream-200);
    margin: 0.5rem 0;
  }

  .section { padding: 2.5rem 0; }

  .section-heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: var(--ink-900);
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
  }

  /* ── Features bento ───────────────── */
  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--cream-300);
    border: 1.5px solid var(--cream-300);
    border-radius: 8px;
    overflow: hidden;
  }

  .feature {
    background: var(--bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.12s;
  }

  .feature:hover { background: var(--cream-100); }

  .feature-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ink-900);
    margin: 0;
  }

  .feature-desc {
    font-size: 0.85rem;
    color: var(--ink-500);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Responsive ───────────────────── */
  @media (max-width: 800px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem 0;
    }

    /* Logo above text on mobile */
    .hero-right { order: -1; justify-content: center; }

    .hero-logo {
      max-width: 85vw;
      width: 85vw;
    }

    h1 { font-size: 2.6rem; }

    .features { grid-template-columns: 1fr; }
  }
</style>
