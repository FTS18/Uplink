---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- HERO ─────────────────────────────── -->
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">Open-source · Windows native · MIT License</p>
      <h1>Your network speed.<br /><em>Always visible.</em></h1>
      <p class="hero-desc">
        BitBar lives directly in your Windows 11 taskbar — showing live upload and download speeds, zero electron, zero background services.
      </p>
      <div class="hero-actions">
        <a href="https://github.com/FTS18/BitBar/releases" target="_blank" rel="noopener noreferrer" class="btn btn-dark">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download BitBar.exe
        </a>
        <a href="/docs/install" class="btn btn-outline">
          Read the docs →
        </a>
      </div>
      <div class="hero-badges">
        <span class="badge">Windows 11</span>
        <span class="badge">No background service</span>
        <span class="badge">.NET 10 · ~5 MB</span>
      </div>
    </div>

    <!-- Flyout Widget Mockup -->
    <div class="widget-wrap">
      <p class="widget-label">Live Preview</p>
      <div class="widget">
        <div class="widget-row">
          <span class="widget-key">Consumer</span>
          <span class="widget-val">chrome.exe</span>
        </div>
        <div class="widget-sep"></div>
        <div class="widget-row">
          <span class="widget-key">Download</span>
          <span class="widget-val speed-down">142.8 KB/s</span>
        </div>
        <div class="widget-sep"></div>
        <div class="widget-row">
          <span class="widget-key">Upload</span>
          <span class="widget-val speed-up">48.2 KB/s</span>
        </div>
        <div class="widget-sep"></div>
        <div class="widget-graph">
          <svg viewBox="0 0 230 60" preserveAspectRatio="none" class="graph-svg">
            <defs>
              <linearGradient id="g1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="currentColor" stop-opacity="0.18"/>
                <stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0 60 L0 42 C40 15,60 50,90 20 S150 38,190 10 L230 18 L230 60 Z" fill="url(#g1)" class="graph-fill"/>
            <path d="M0 42 C40 15,60 50,90 20 S150 38,190 10 L230 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="graph-line"/>
          </svg>
          <span class="graph-hint">60s history</span>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER ───────────────────────────── -->
  <div class="section-divider"></div>

  <!-- FEATURES ──────────────────────────── -->
  <section class="section">
    <h2 class="section-title">Why BitBar?</h2>
    <div class="features">
      <div class="feature">
        <div class="feature-icon">⚡</div>
        <h3>Taskbar-native</h3>
        <p>Renders directly inside the Windows 11 taskbar — no floating windows, no system tray clutter.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🔍</div>
        <h3>Process tracking</h3>
        <p>Hover to instantly see which app is hogging your bandwidth — Chrome, Steam, a backup daemon.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">🌙</div>
        <h3>Theme-aware</h3>
        <p>Detects light and dark system themes automatically, always looking native and sharp.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">💤</div>
        <h3>Auto-fade on idle</h3>
        <p>Fades gracefully when the network is quiet so it never distracts you when nothing's happening.</p>
      </div>
    </div>
  </section>

  <!-- DIVIDER ───────────────────────────── -->
  <div class="section-divider"></div>

  <!-- SPECS ─────────────────────────────── -->
  <section class="section">
    <h2 class="section-title">Requirements</h2>
    <div class="prose">
      <table>
        <thead>
          <tr><th>Requirement</th><th>Detail</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>OS</strong></td><td>Windows 10 22H2 or later (Windows 11 recommended)</td></tr>
          <tr><td><strong>Runtime</strong></td><td>.NET 10.0 Desktop Runtime (x64)</td></tr>
          <tr><td><strong>Disk</strong></td><td>Under 5 MB (single-file executable)</td></tr>
          <tr><td><strong>RAM</strong></td><td>~20 MB during active monitoring</td></tr>
          <tr><td><strong>CPU</strong></td><td>&lt;0.1% on modern hardware</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ─────────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
    padding: 3.5rem 0 3rem;
  }

  .hero-text { display: flex; flex-direction: column; gap: 1.25rem; }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-300);
  }

  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.25rem;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--ink-900);
  }
  h1 em { font-style: italic; color: var(--ink-500); }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--ink-500);
    line-height: 1.65;
    max-width: 46ch;
  }

  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .hero-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }
  .badge {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-500);
    background: var(--cream-200);
    border: 1px solid var(--cream-300);
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  /* ── Widget Mockup ────────────────── */
  .widget-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .widget-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-300);
  }

  .widget {
    width: 240px;
    background: var(--cream-100);
    border: 1.5px solid var(--cream-300);
    border-radius: 10px;
    padding: 12px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .widget-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 0.83rem;
  }
  .widget-key { color: var(--ink-300); font-weight: 500; }
  .widget-val { font-weight: 700; color: var(--ink-900); font-family: 'IBM Plex Mono', monospace; }
  .speed-down { color: #2a8a50; }
  .speed-up   { color: #c74b2f; }

  .widget-sep { height: 1px; background: var(--cream-300); }

  .widget-graph {
    background: var(--bg);
    border: 1px solid var(--cream-300);
    border-radius: 6px;
    height: 60px;
    overflow: hidden;
    position: relative;
    color: var(--ink-700);
  }
  .graph-svg { width: 100%; height: 100%; }
  .graph-fill { color: var(--ink-700); fill: currentColor; }
  .graph-line { color: var(--ink-700); stroke: currentColor; }
  .graph-hint {
    position: absolute;
    bottom: 4px;
    left: 7px;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-300);
  }

  /* ── Sections ─────────────────────── */
  .section-divider {
    height: 1.5px;
    background: var(--cream-200);
    margin: 0.5rem 0;
  }

  .section { padding: 2.5rem 0; }

  .section-title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: var(--ink-900);
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }

  /* ── Features Grid ────────────────── */
  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    border: 1.5px solid var(--cream-300);
    border-radius: var(--r);
    overflow: hidden;
    background: var(--cream-300);
  }

  .feature {
    background: var(--bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.15s;
  }
  .feature:hover { background: var(--cream-100); }

  .feature-icon { font-size: 1.4rem; }

  .feature h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink-900);
  }
  .feature p { font-size: 0.875rem; color: var(--ink-500); line-height: 1.6; }

  /* ── Responsive ───────────────────── */
  @media (max-width: 800px) {
    .hero { grid-template-columns: 1fr; gap: 2.5rem; padding: 2rem 0; }
    .widget-wrap { align-items: flex-start; }
    h1 { font-size: 2.5rem; }
    .features { grid-template-columns: 1fr; }
  }
</style>
