---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <p class="eyebrow">Open-source &middot; Windows native &middot; MIT License</p>
      <h1>Your network speed.<br /><em>Always visible.</em></h1>
      <p class="hero-desc">
        BitBar lives directly in your Windows 11 taskbar — showing live upload and download speeds with no Electron, no background service, and no bloat.
      </p>
      <div class="hero-actions">
        <a href="https://github.com/FTS18/BitBar/releases" target="_blank" rel="noopener noreferrer" class="btn btn-dark">
          Download BitBar.exe
        </a>
        <a href="/docs/install" class="btn btn-outline">Read the docs</a>
      </div>
      <div class="hero-badges">
        <span class="badge">Windows 11</span>
        <span class="badge">No background service</span>
        <span class="badge">.NET 10 &middot; ~5 MB</span>
      </div>
    </div>

    <div class="hero-right">
      <p class="preview-label">Flyout Preview</p>
      <div class="widget">
        <div class="widget-row">
          <span class="wk">Consumer</span>
          <span class="wv">chrome.exe</span>
        </div>
        <hr class="whr" />
        <div class="widget-row">
          <span class="wk">Download</span>
          <span class="wv wv-down">142.8 KB/s</span>
        </div>
        <hr class="whr" />
        <div class="widget-row">
          <span class="wk">Upload</span>
          <span class="wv wv-up">48.2 KB/s</span>
        </div>
        <hr class="whr" />
        <div class="widget-graph">
          <svg viewBox="0 0 220 56" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="g" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1A1813" stop-opacity="0.12"/>
                <stop offset="100%" stop-color="#1A1813" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0 40 C30 10,50 48,80 22 S130 40,165 12 L220 20 L220 56 L0 56 Z" fill="url(#g)"/>
            <path d="M0 40 C30 10,50 48,80 22 S130 40,165 12 L220 20" fill="none" stroke="#1A1813" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="graph-label">60 second history</span>
        </div>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  <!-- FEATURES -->
  <section class="section">
    <h2 class="section-heading">Why BitBar?</h2>
    <div class="features">
      <div class="feature">
        <p class="feature-title">Taskbar-native</p>
        <p class="feature-desc">Renders directly inside the Windows 11 taskbar. No floating windows, no system tray clutter.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Process tracking</p>
        <p class="feature-desc">Hover to instantly see which application is consuming the most bandwidth at any given moment.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Theme-aware</p>
        <p class="feature-desc">Detects light and dark system themes automatically, rendering natively in both modes.</p>
      </div>
      <div class="feature">
        <p class="feature-title">Auto-fade on idle</p>
        <p class="feature-desc">Fades gracefully when the network is quiet. Zero visual noise when nothing is happening.</p>
      </div>
    </div>
  </section>

  <div class="rule"></div>

  <!-- SPECS -->
  <section class="section">
    <h2 class="section-heading">System Requirements</h2>
    <div class="prose">
      <table>
        <thead>
          <tr><th>Requirement</th><th>Detail</th></tr>
        </thead>
        <tbody>
          <tr><td>Operating System</td><td>Windows 10 22H2 or later (Windows 11 recommended)</td></tr>
          <tr><td>Runtime</td><td>.NET 10.0 Desktop Runtime (x64)</td></tr>
          <tr><td>Disk space</td><td>Under 5 MB (single-file executable)</td></tr>
          <tr><td>Memory</td><td>~20 MB RAM during active monitoring</td></tr>
          <tr><td>CPU overhead</td><td>Less than 0.1% on typical modern hardware</td></tr>
        </tbody>
      </table>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ─────────────────────── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    align-items: start;
    padding: 3.5rem 0 3rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 540px;
  }

  .eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-300);
  }

  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.25rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink-900);
    margin: 0;
  }

  h1 em {
    font-style: italic;
    color: var(--ink-500);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--ink-500);
    line-height: 1.7;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    font-size: 0.73rem;
    font-weight: 600;
    color: var(--ink-400, var(--ink-500));
    background: var(--cream-200);
    border: 1px solid var(--cream-300);
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
  }

  /* ── Widget ───────────────────── */
  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .preview-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-300);
    margin: 0;
  }

  .widget {
    background: var(--cream-100);
    border: 1.5px solid var(--cream-300);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 7px;
    box-shadow:
      0 2px 8px rgba(0,0,0,0.06),
      0 1px 3px rgba(0,0,0,0.04);
    width: 240px;
  }

  .widget-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .wk {
    font-size: 0.8rem;
    color: var(--ink-300);
    font-weight: 500;
  }

  .wv {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-900);
  }

  .wv-down { color: #2a7a46; }
  .wv-up   { color: #a03020; }

  .whr {
    border: none;
    border-top: 1px solid var(--cream-300);
    margin: 0;
  }

  .widget-graph {
    background: var(--bg);
    border: 1px solid var(--cream-300);
    border-radius: 5px;
    overflow: hidden;
    position: relative;
    height: 56px;
  }

  .widget-graph svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .graph-label {
    position: absolute;
    bottom: 4px;
    left: 7px;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-300);
  }

  /* ── Shared ───────────────────── */
  .rule {
    height: 1.5px;
    background: var(--cream-200);
    margin: 0.5rem 0;
  }

  .section { padding: 2.5rem 0; }

  .section-heading {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 400;
    color: var(--ink-900);
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
  }

  /* ── Features Bento ───────────── */
  .features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--cream-300);
    border: 1.5px solid var(--cream-300);
    border-radius: 8px;
    overflow: hidden;
  }

  .feature {
    background: var(--bg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.12s;
  }

  .feature:hover { background: var(--cream-100); }

  .feature-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--ink-900);
    margin: 0;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--ink-500);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Responsive ───────────────── */
  @media (max-width: 800px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2rem 0;
    }
    h1 { font-size: 2.25rem; }
    .widget { width: 100%; }
    .features { grid-template-columns: 1fr; }
  }
</style>
